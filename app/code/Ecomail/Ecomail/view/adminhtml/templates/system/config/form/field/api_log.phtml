<?php /** @var \Ecomail\Ecomail\Block\System\Config\Form\Field\ApiLog $block */ ?>
<?php $logs = $block->getRecentLogs(); ?>

<div class="ecomail-api-log-panel">
    <div class="ecomail-api-log-header">
        <span class="ecomail-api-log-title"><?= $block->escapeHtml(__('Recent API Requests')) ?></span>
        <span class="ecomail-api-log-count">
            <?= $block->escapeHtml(__('%1 shown', count($logs))) ?>
        </span>
    </div>

    <?php if (!$logs): ?>
        <div class="ecomail-api-log-empty">
            <?= $block->escapeHtml(__('No Ecomail API requests logged yet.')) ?>
        </div>
    <?php else: ?>
        <div class="ecomail-api-log-list">
            <?php foreach ($logs as $log): ?>
                <?php $success = (int)$log['success']; ?>
                <div class="ecomail-api-log-row <?= $success ? 'is-ok' : 'is-error' ?>">
                    <div class="ecomail-api-log-main">
                        <span class="ecomail-api-log-method"><?= $block->escapeHtml($log['method']) ?></span>
                        <span class="ecomail-api-log-endpoint"><?= $block->escapeHtml($log['endpoint']) ?></span>
                    </div>
                    <div class="ecomail-api-log-meta">
                        <span class="ecomail-api-log-time"><?= $block->escapeHtml($log['created_at']) ?></span>
                        <span class="ecomail-api-log-badge <?= $success ? 'is-ok' : 'is-error' ?>">
                            <?= $success ? $block->escapeHtml(__('OK')) : $block->escapeHtml(__('Error')) ?>
                        </span>
                        <span><?= $block->escapeHtml($log['status_code'] ?: '-') ?></span>
                        <span><?= $block->escapeHtml($log['duration_ms'] !== null ? $log['duration_ms'] . ' ms' : '-') ?></span>
                    </div>
                    <?php if (!empty($log['message'])): ?>
                        <div class="ecomail-api-log-message">
                            <?= $block->escapeHtml($log['message']) ?>
                        </div>
                    <?php endif; ?>
                </div>
            <?php endforeach; ?>
        </div>
        <p class="note">
            <span><?= $block->escapeHtml(__('Showing the last 10 compact request logs. Old log rows are cleaned automatically.')) ?></span>
        </p>
    <?php endif; ?>
</div>

