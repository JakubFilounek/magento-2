<script>
    require(['jquery'], function ($) {
        var state = <?= /* @noEscape */ json_encode($state ?: []) ?>;

        function render(nextState) {
            state = nextState || {};
            var totalCustomers = parseInt(state.total_customers || 0, 10);
            var totalOrders = parseInt(state.total_orders || 0, 10);
            var processedCustomers = Math.min(parseInt(state.processed_customers || 0, 10), totalCustomers);
            var processedOrders = Math.min(parseInt(state.processed_orders || 0, 10), totalOrders);
            var total = totalCustomers + totalOrders;
            var processed = processedCustomers + processedOrders;
            var percent = total ? Math.round((processed / total) * 100) : 0;
            var status = state.status || '<?= $block->escapeJs(__('Not started')) ?>';
            var statusClass = String(status).toLowerCase().replace(/[^a-z0-9_-]/g, '-');

            $('#ecomail_sync_status')
                .removeClass('is-completed is-running is-pending is-failed')
                .addClass('is-' + statusClass)
                .text(status);
            $('#ecomail_sync_bar').css('width', percent + '%');
            $('#ecomail_sync_percent').text(percent + '%');
            $('#ecomail_sync_count').text(processed + '/' + total);
            $('#ecomail_sync_customers').text(processedCustomers + '/' + totalCustomers);
            $('#ecomail_sync_orders').text(processedOrders + '/' + totalOrders);
            $('#ecomail_sync_message').text(state.last_message || '');
            $('#ecomail_sync_message_time').text(state.updated_at ? '(' + state.updated_at + ')' : '');
        }

        function refreshStatus() {
            $.getJSON('<?= $block->escapeJs($block->getStatusUrl()) ?>', function (response) {
                render(response.state || {});
            });
        }

        function configValue(group, field) {
            var selector = '[name="groups[' + group + '][fields][' + field + '][value]"]';
            var element = $(selector);

            return element.length ? element.val() : '';
        }

        $('#ecomail_start_sync').on('click', function () {
            $.ajax({
                url: '<?= $block->escapeJs($block->getStartUrl()) ?>',
                dataType: 'json',
                method: 'post',
                data: {
                    form_key: window.FORM_KEY,
                    store_id: '<?= $block->escapeJs((string)$block->getStoreId()) ?>',
                    sync_customers: 1,
                    sync_orders: 1,
                    update_existing: configValue('general', 'sync_update_existing'),
                    include_tags: configValue('general', 'sync_include_tags'),
                    customer_batch_size: configValue('general', 'sync_customer_batch_size'),
                    order_batch_size: configValue('general', 'sync_order_batch_size')
                },
                success: function (response) {
                    render(response.state || {});
                }
            });
        });

        render(state);
        window.setInterval(refreshStatus, 10000);
    });
</script>
