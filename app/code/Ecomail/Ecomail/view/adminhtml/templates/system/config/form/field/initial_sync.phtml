<script>
    require(['jquery'], function ($) {
        var initialState = <?= /* @noEscape */ json_encode(
            $state ?: [],
            JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT
        ) ?>;

        var STATUS_LABELS = {
            idle:      '<?= $block->escapeJs(__('Idle')) ?>',
            pending:   '<?= $block->escapeJs(__('Queued')) ?>',
            running:   '<?= $block->escapeJs(__('Syncing')) ?>',
            completed: '<?= $block->escapeJs(__('Completed')) ?>',
            failed:    '<?= $block->escapeJs(__('Failed')) ?>'
        };

        var HEADLINES = {
            idle:      '<?= $block->escapeJs(__('Ready to sync')) ?>',
            pending:   '<?= $block->escapeJs(__('Queued for the next cron run')) ?>',
            running:   '<?= $block->escapeJs(__('Sync in progress')) ?>',
            completed: '<?= $block->escapeJs(__('Sync complete')) ?>',
            failed:    '<?= $block->escapeJs(__('Sync failed')) ?>'
        };

        var SUBTITLES = {
            idle:      '<?= $block->escapeJs(__('Send your existing customers and orders to Ecomail in batches.')) ?>',
            pending:   '<?= $block->escapeJs(__('Waiting for Magento cron to pick up the job.')) ?>',
            running:   '<?= $block->escapeJs(__('Cron is processing batches. You can safely leave this page.')) ?>',
            completed: '<?= $block->escapeJs(__('You can run another sync at any time.')) ?>',
            failed:    '<?= $block->escapeJs(__('The previous run did not finish. Review the message below and try again.')) ?>'
        };

        var $root     = $('#ecomail_sync_root');
        var $headline = $('#ecomail_sync_headline');
        var $subtitle = $('#ecomail_sync_subtitle');
        var $badge    = $('#ecomail_sync_status');
        var $badgeText = $badge.find('.ecomail-sync__badge-text');
        var $active   = $('#ecomail_sync_active');
        var $bar      = $('#ecomail_sync_bar');
        var $percent  = $('#ecomail_sync_percent');
        var $count    = $('#ecomail_sync_count');
        var $customers = $('#ecomail_sync_customers');
        var $orders   = $('#ecomail_sync_orders');
        var $message  = $('#ecomail_sync_message');
        var $last     = $('#ecomail_sync_last');
        var $lastSummary = $('#ecomail_sync_last_summary');
        var $lastTime = $('#ecomail_sync_last_time');
        var $lastLabel = $('#ecomail_sync_last_label');
        var $button   = $('#ecomail_start_sync');
        var $buttonLabel = $('#ecomail_start_sync_label');

        var BUTTON_LABEL_DEFAULT = '<?= $block->escapeJs(__('Start sync')) ?>';
        var BUTTON_LABEL_RESYNC  = '<?= $block->escapeJs(__('Run sync again')) ?>';
        var BUTTON_LABEL_RUNNING = '<?= $block->escapeJs(__('Sync running…')) ?>';

        // Tracks whether we are currently showing an active (running/pending) sync.
        // When the active sync finishes, we collapse the live progress UI into a
        // "Last sync" summary instead of leaving the old progress bar lingering.
        var showingActive = false;

        function normalizeStatus(raw) {
            var status = String(raw || '').toLowerCase().trim();
            if (status === 'pending' || status === 'running' || status === 'completed' || status === 'failed') {
                return status;
            }
            return 'idle';
        }

        function isActive(status) {
            return status === 'pending' || status === 'running';
        }

        function setVisible($el, visible) {
            if (visible) {
                $el.prop('hidden', false);
                // Next frame so the CSS transition kicks in.
                window.requestAnimationFrame(function () {
                    $el.addClass('is-visible');
                });
            } else {
                $el.removeClass('is-visible');
                window.setTimeout(function () {
                    if (!$el.hasClass('is-visible')) {
                        $el.prop('hidden', true);
                    }
                }, 250);
            }
        }

        function resetActivePanel() {
            $bar.css('width', '0%');
            $percent.text('0%');
            $count.text('0 / 0');
            $customers.text('0 / 0');
            $orders.text('0 / 0');
            $message.text('—');
            $active.removeAttr('data-status');
        }

        function summarize(state) {
            var totalCustomers = parseInt(state.total_customers || 0, 10);
            var totalOrders    = parseInt(state.total_orders || 0, 10);
            var doneCustomers  = Math.min(parseInt(state.processed_customers || 0, 10), totalCustomers);
            var doneOrders     = Math.min(parseInt(state.processed_orders || 0, 10), totalOrders);
            var total          = totalCustomers + totalOrders;
            var processed      = doneCustomers + doneOrders;
            var percent        = total ? Math.round((processed / total) * 100) : 0;

            return {
                totalCustomers: totalCustomers,
                totalOrders: totalOrders,
                doneCustomers: doneCustomers,
                doneOrders: doneOrders,
                total: total,
                processed: processed,
                percent: percent
            };
        }

        function describeFinished(state, sums) {
            var parts = [];
            if (sums.doneCustomers || sums.totalCustomers) {
                parts.push(sums.doneCustomers + ' <?= $block->escapeJs(__('customers')) ?>');
            }
            if (sums.doneOrders || sums.totalOrders) {
                parts.push(sums.doneOrders + ' <?= $block->escapeJs(__('orders')) ?>');
            }
            var counts = parts.length ? parts.join(' · ') : '<?= $block->escapeJs(__('Nothing to sync')) ?>';
            var msg = (state.last_message || '').toString().trim();
            return msg ? counts + ' — ' + msg : counts;
        }

        function render(rawState) {
            var state = rawState || {};
            var status = normalizeStatus(state.status);
            var sums   = summarize(state);

            $badge.attr('data-status', status);
            $badgeText.text(STATUS_LABELS[status]);
            $headline.text(HEADLINES[status]);
            $subtitle.text(SUBTITLES[status]);

            if (isActive(status)) {
                showingActive = true;
                $active.attr('data-status', status);
                $bar.css('width', sums.percent + '%');
                $percent.text(sums.percent + '%');
                $count.text(sums.processed + ' / ' + sums.total);
                $customers.text(sums.doneCustomers + ' / ' + sums.totalCustomers);
                $orders.text(sums.doneOrders + ' / ' + sums.totalOrders);
                $message.text(state.last_message || '—');
                setVisible($active, true);
                setVisible($last, false);

                $buttonLabel.text(BUTTON_LABEL_RUNNING);
                $button.prop('disabled', true);
                return;
            }

            // Not active. If we *were* showing an active panel, this is the moment
            // the run finished — reset live progress and surface a "Last sync" card.
            if (showingActive) {
                showingActive = false;
                resetActivePanel();
                setVisible($active, false);
            }

            if (status === 'completed' || status === 'failed') {
                $last.attr('data-status', status);
                $lastLabel.text(
                    status === 'failed'
                        ? '<?= $block->escapeJs(__('Last sync — failed')) ?>'
                        : '<?= $block->escapeJs(__('Last sync')) ?>'
                );
                $lastSummary.text(describeFinished(state, sums));
                $lastTime.text(state.finished_at || state.updated_at || '');
                setVisible($last, true);
            } else {
                setVisible($last, false);
            }

            $buttonLabel.text(status === 'idle' ? BUTTON_LABEL_DEFAULT : BUTTON_LABEL_RESYNC);
            $button.prop('disabled', false);
        }

        function refreshStatus() {
            $.getJSON('<?= $block->escapeJs($block->getStatusUrl()) ?>', function (response) {
                render(response.state || {});
            });
        }

        function configValue(group, field) {
            var selector = '[name="groups[' + group + '][fields][' + field + '][value]"]';
            var element = $(selector);
            return element.length ? element.val() : '';
        }

        $button.on('click', function () {
            if ($button.prop('disabled')) {
                return;
            }
            // Optimistically reset the visible progress so the user doesn't see
            // the previous run's bar pinned at 100% (or wherever it stopped).
            resetActivePanel();
            setVisible($last, false);
            $buttonLabel.text(BUTTON_LABEL_RUNNING);
            $button.prop('disabled', true);

            $.ajax({
                url: '<?= $block->escapeJs($block->getStartUrl()) ?>',
                dataType: 'json',
                method: 'post',
                data: {
                    form_key: window.FORM_KEY,
                    store_id: '<?= $block->escapeJs((string)$block->getStoreId()) ?>',
                    sync_customers: 1,
                    sync_orders: 1,
                    update_existing: configValue('general', 'sync_update_existing'),
                    include_tags: configValue('general', 'sync_include_tags'),
                    customer_batch_size: configValue('general', 'sync_customer_batch_size'),
                    order_batch_size: configValue('general', 'sync_order_batch_size')
                },
                success: function (response) {
                    render(response.state || {});
                },
                error: function () {
                    $button.prop('disabled', false);
                    $buttonLabel.text(BUTTON_LABEL_DEFAULT);
                }
            });
        });

        render(initialState);
        window.setInterval(refreshStatus, 5000);
    });
</script>
