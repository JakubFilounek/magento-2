<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <ecomail>
            <general>
                <enabled>0</enabled>
                <skip_double_optin>1</skip_double_optin>
                <trigger_autoresponders>0</trigger_autoresponders>
                <sync_existing>0</sync_existing>
                <sync_include_tags>0</sync_include_tags>
                <sync_update_existing>1</sync_update_existing>
                <sync_customer_batch_size>3000</sync_customer_batch_size>
                <sync_order_batch_size>1000</sync_order_batch_size>
                <checkout_opt_out_label>Do not subscribe me to the newsletter</checkout_opt_out_label>
            </general>
            <personal_information>
                <send_name>1</send_name>
                <send_address>1</send_address>
                <address_type>1</address_type>
                <send_dob>1</send_dob>
                <send_orders>1</send_orders>
                <update_contacts_from_orders>1</update_contacts_from_orders>
                <send_cart_items>1</send_cart_items>
                <send_groups>1</send_groups>
                <send_locale>1</send_locale>
            </personal_information>
            <tracking>
                <enabled>0</enabled>
                <respect_cookie_consent>1</respect_cookie_consent>
                <product_view>1</product_view>
                <form_enabled>0</form_enabled>
            </tracking>
        </ecomail>
    </default>
</config>
