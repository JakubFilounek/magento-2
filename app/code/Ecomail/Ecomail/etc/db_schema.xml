<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="ecomail_sync_state" resource="default" engine="innodb" comment="Ecomail Sync State">
        <column xsi:type="int" name="state_id" padding="10" unsigned="true" nullable="false" identity="true" comment="State ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="true" comment="Store ID"/>
        <column xsi:type="varchar" name="status" nullable="false" length="32" default="pending" comment="Status"/>
        <column xsi:type="smallint" name="sync_customers" unsigned="true" nullable="false" default="1" comment="Sync Customers"/>
        <column xsi:type="smallint" name="sync_orders" unsigned="true" nullable="false" default="1" comment="Sync Orders"/>
        <column xsi:type="smallint" name="update_existing" unsigned="true" nullable="false" default="1" comment="Update Existing Contacts"/>
        <column xsi:type="smallint" name="include_tags" unsigned="true" nullable="false" default="0" comment="Include Tags"/>
        <column xsi:type="int" name="batch_size" unsigned="true" nullable="false" default="100" comment="Batch Size"/>
        <column xsi:type="int" name="customer_batch_size" unsigned="true" nullable="false" default="3000" comment="Customer Batch Size"/>
        <column xsi:type="int" name="order_batch_size" unsigned="true" nullable="false" default="1000" comment="Order Batch Size"/>
        <column xsi:type="int" name="total_customers" unsigned="true" nullable="false" default="0" comment="Total Customers"/>
        <column xsi:type="int" name="processed_customers" unsigned="true" nullable="false" default="0" comment="Processed Customers"/>
        <column xsi:type="int" name="total_orders" unsigned="true" nullable="false" default="0" comment="Total Orders"/>
        <column xsi:type="int" name="processed_orders" unsigned="true" nullable="false" default="0" comment="Processed Orders"/>
        <column xsi:type="varchar" name="last_message" nullable="true" length="255" comment="Last Message"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <column xsi:type="timestamp" name="started_at" nullable="true" comment="Started At"/>
        <column xsi:type="timestamp" name="finished_at" nullable="true" comment="Finished At"/>
        <column xsi:type="timestamp" name="locked_at" nullable="true" comment="Locked At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="state_id"/>
        </constraint>
        <index referenceId="ECOMAIL_SYNC_STATE_STATUS" indexType="btree">
            <column name="status"/>
            <column name="locked_at"/>
        </index>
    </table>
    <table name="ecomail_api_log" resource="default" engine="innodb" comment="Ecomail API Log">
        <column xsi:type="bigint" name="log_id" padding="20" unsigned="true" nullable="false" identity="true" comment="Log ID"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="varchar" name="method" nullable="false" length="10" comment="HTTP Method"/>
        <column xsi:type="varchar" name="endpoint" nullable="false" length="255" comment="Endpoint"/>
        <column xsi:type="int" name="status_code" unsigned="true" nullable="true" comment="HTTP Status"/>
        <column xsi:type="smallint" name="success" unsigned="true" nullable="false" default="0" comment="Success"/>
        <column xsi:type="int" name="duration_ms" unsigned="true" nullable="true" comment="Duration Ms"/>
        <column xsi:type="varchar" name="message" nullable="true" length="255" comment="Message"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="log_id"/>
        </constraint>
        <index referenceId="ECOMAIL_API_LOG_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
        <index referenceId="ECOMAIL_API_LOG_SUCCESS" indexType="btree">
            <column name="success"/>
        </index>
    </table>
</schema>
