{
    "name": "ecomailcz/magento2-ecomail",
    "description": "Connect Magento 2 stores with Ecomail email marketing and automation services.",
    "version": "2.3.0",
    "keywords": [
        "magento2",
        "adobe-commerce",
        "ecomail",
        "email-marketing",
        "newsletter",
        "marketing-automation"
    ],
    "homepage": "https://www.ecomail.cz/",
    "license": [
        "OSL-3.0",
        "AFL-3.0"
    ],
    "authors": [
        {
            "name": "Ecomail",
            "email": "support@ecomail.cz"
        }
    ],
    "require": {
        "php": ">=8.1 <8.6",
        "magento/framework": ">=103.0 <105.0",
        "magento/module-newsletter": ">=100.4.0 <100.5.0",
        "magento/module-sales": ">=103.0.0 <104.0.0",
        "magento/module-customer": ">=103.0.0 <104.0.0",
        "magento/module-catalog": ">=104.0.0 <105.0.0",
        "magento/module-checkout": ">=100.4.0 <100.5.0",
        "magento/module-store": ">=101.1.0 <101.2.0",
        "magento/module-quote": ">=101.2.0 <101.3.0",
        "magento/module-backend": ">=102.0.0 <102.1.0",
        "magento/module-config": ">=101.2.0 <101.3.0",
        "ext-curl": "*"
    },
    "type": "magento2-module",
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Ecomail\\Ecomail\\": ""
        }
    },
    "support": {
        "email": "support@ecomail.cz",
        "docs": "https://support.ecomail.cz/"
    }
}
